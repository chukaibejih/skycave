# --- Bluesky / AT Protocol OAuth (runs in the Node oauth-sidecar) ---
# Public base URL of this backend.
PUBLIC_API_URL=https://api.skycave.space
# Internal URL FastAPI uses to reach the sidecar (Docker network service name).
OAUTH_SIDECAR_URL=http://oauth-sidecar:3001
# Shared secret FastAPI sends to the sidecar's internal /oauth/session endpoint.
# Must match the sidecar's OAUTH_INTERNAL_SECRET.
OAUTH_INTERNAL_SECRET=

# --- Datastores ---
DATABASE_URL=postgresql+asyncpg://skycave:skycave@db:5432/skycave
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- Backoffice (admin dashboard) ---
# Set to a strong secret to enable /admin login. Empty = admin disabled.
ADMIN_PASSWORD=

# --- Frontend ---
FRONTEND_URL=https://skycave.space

# --- App ---
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://skycave.space,http://localhost:3000
ENV=development
