# Public base where nginx serves this sidecar (api.skycave.space/oauth/*)
PUBLIC_OAUTH_BASE=https://api.skycave.space/oauth
FRONTEND_URL=https://skycave.space

# ES256 private key (PEM). In Docker this is provided via a mounted FILE
# (OAUTH_PRIVATE_KEY_FILE, set in docker-compose.yml) — do NOT put the multi-line
# PEM here; env_file can't carry it. For non-Docker runs you may instead set
# OAUTH_PRIVATE_KEY to a base64 blob (`base64 -w0 oauth-private-key.pem`).
# Generate the key with:
#   openssl genpkey -algorithm EC -pkeyopt ec_paramgen_curve:P-256 -pkeyopt ec_param_enc:named_curve | openssl pkcs8 -topk8 -nocrypt -outform pem > oauth-private-key.pem
# OAUTH_PRIVATE_KEY=

# Secret used to sign the browser session cookie (long random string)
SESSION_SECRET=

# Shared secret FastAPI must send (x-internal-secret) to call /oauth/session
OAUTH_INTERNAL_SECRET=

# Cookie scoping — set to the shared parent domain in prod so api.* + the app
# subdomain both see it. Leave blank for localhost.
COOKIE_DOMAIN=.skycave.space
# Set to "false" only for local http testing
COOKIE_SECURE=true

PORT=3001
